{  "drift_detection_version": "1.0.0",  "purpose": "Automated detection of taxonomy drift in damage descriptions",    "drift_categories": {    "generic_glitchcore": {      "indicators": [        "uses 'glitchy' without specification",        "uses 'broken' as primary descriptor",        "random RGB split without cause",        "decorative distortion without medium"      ],      "severity": "high",      "recommended_action": "require medium and artifact specificity"    },        "retro_fetish": {      "indicators": [        "uses 'retro' without era or medium",        "scanlines without CRT context",        "film grain without stock or cause",        "VHS label without actual VHS artifacts"      ],      "severity": "medium",      "recommended_action": "require authentic medium behavior"    },        "dirt_overlay": {      "indicators": [        "dust/grain/scratches/fog treated as interchangeable",        "no distinction between contamination types",        "uniform overlay without placement logic"      ],      "severity": "medium",      "recommended_action": "specify contamination type and location"    },        "blur_mush": {      "indicators": [        "all softness collapsed into 'blur'",        "no distinction between defocus, diffusion, smear, bloom, halation",        "uniform Gaussian blur as catchall"      ],      "severity": "medium",      "recommended_action": "specify blur type and cause"    },        "horror_shorthand": {      "indicators": [        "all damage implies dread or threat",        "no other affective modes allowed",        "VHS automatically 'creepy'",        "static automatically 'scary'"      ],      "severity": "low",      "recommended_action": "allow multiple affective modes"    },        "medium_confusion": {      "indicators": [        "VHS artifacts on digital-only image",        "film grain with digital codec blocking no chain",        "analog signal artifacts on scanned photograph",        "temporal artifacts on still image without explanation"      ],      "severity": "high",      "recommended_action": "require chain logic or mark as hybrid"    }  },    "weak_language_blacklist": [    "glitchy",    "corrupted",    "retro",    "broken",    "damaged",    "noisy",    "lo-fi",    "analog",    "old-school",    "distorted",    "vibes",    "aesthetic",    "effect",    "filter",    "look"  ],    "validation_tests": {    "medium_test": "Can a specific medium be identified?",    "artifact_test": "Can specific artifact behavior be identified?",    "cause_test": "Is there implied or stated cause?",    "severity_test": "Can severity be estimated?",    "differentiation_test": "Does it meaningfully differ from neighboring concepts?"  }}